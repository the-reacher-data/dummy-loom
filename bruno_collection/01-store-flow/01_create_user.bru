meta {
  name: flow_create_user
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/users/
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "full_name": "Bruno User",
    "email": "bruno.user@example.com"
  }
}

tests {
  test("status is 201", function() {
    expect(res.getStatus()).to.equal(201);
  });
  const body = res.getBody();
  if (body && body.id) {
    bru.setVar("userId", String(body.id));
  }
}
