meta {
  name: flow_list_products_cursor
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/products/?pagination=cursor&limit=1&sort=id&direction=ASC
  body: none
  auth: none
}

settings {
  encodeUrl: true
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  const body = res.getBody();
  if (body && body.next_cursor) {
    bru.setVar("cursor", String(body.next_cursor));
  }
}
