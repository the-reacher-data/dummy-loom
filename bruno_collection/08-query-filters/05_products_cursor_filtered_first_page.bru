meta {
  name: query_products_cursor_filtered_first_page
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/products/?category__eq=peripherals&pagination=cursor&limit=2&sort=id&direction=ASC
  body: none
  auth: none
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  const body = res.getBody();
  if (body && body.next_cursor) {
    bru.setVar("cursor", String(body.next_cursor));
  }
}
